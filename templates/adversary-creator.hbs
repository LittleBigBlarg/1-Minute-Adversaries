<div class="dhac-layout">

  {{!-- ==================== TOP BAR ==================== --}}
  <div class="dhac-topbar">
    <div class="dhac-actor-image-controls">
      <button
        type="button"
        class="dhac-actor-image-btn"
        data-action="pickActorImage"
        title="Choose adversary portrait"
      >
        <img src="{{img}}" alt="" class="dhac-actor-image" />
      </button>
      <button
        type="button"
        class="dhac-feature-image-reset-btn"
        data-action="resetActorImage"
        title="Reset portrait"
      >
        <i class="fas fa-rotate-left"></i>
      </button>
      <input type="hidden" name="img" value="{{img}}" />
    </div>
    <div class="dhac-topbar-field dhac-topbar-name">
      <label>Name</label>
      <input type="text" name="name" value="{{name}}" placeholder="e.g. Stone Golem" autofocus />
    </div>
    <div class="dhac-topbar-field dhac-topbar-narrow">
      <label>Tier</label>
      <select name="tier">
        <option value="1" {{#if (eq tier 1)}}selected{{/if}}>1</option>
        <option value="2" {{#if (eq tier 2)}}selected{{/if}}>2</option>
        <option value="3" {{#if (eq tier 3)}}selected{{/if}}>3</option>
        <option value="4" {{#if (eq tier 4)}}selected{{/if}}>4</option>
      </select>
    </div>
    <div class="dhac-topbar-field dhac-topbar-role">
      <label>Role</label>
      <div class="dhac-role-select-row">
        <select name="role">
          {{#each roles}}
          <option value="{{this}}" {{#if (eq this ../role)}}selected{{/if}}>{{capitalize this}}</option>
          {{/each}}
        </select>
        {{#if roleTip}}
        <div class="dhac-role-tip-wrapper">
          <button type="button" class="dhac-role-tip-btn" title="Role design tips">
            <i class="fas fa-circle-info"></i>
          </button>
          <div class="dhac-role-tip-popup">
            <div class="dhac-role-tip-header">{{capitalize role}} Tips</div>
            <div class="dhac-role-tip-summary">{{roleTip.summary}}</div>
            <div class="dhac-role-tip-section">
              <span class="dhac-role-tip-label">Damage:</span> {{roleTip.damage}}
            </div>
            <div class="dhac-role-tip-section">
              <span class="dhac-role-tip-label">Features:</span> {{roleTip.features}}
            </div>
            <div class="dhac-role-tip-section">
              <span class="dhac-role-tip-label">Common:</span> {{roleTip.common}}
            </div>
            <div class="dhac-role-tip-section">
              <span class="dhac-role-tip-label">Experiences:</span> {{roleTip.experiences}}
            </div>
            {{#if roleTip.tip}}
            <div class="dhac-role-tip-extra">
              <i class="fas fa-lightbulb"></i> {{roleTip.tip}}
            </div>
            {{/if}}
            <div class="dhac-role-tip-link">
              <a href="https://docs.google.com/document/d/12g-obIkdGJ_iLL19bS0oKPDDvPbPI9pWUiFqGw8ED88/edit?tab=t.0#heading=h.mdjo15f06zjv"
                 target="_blank" rel="noopener" class="dhac-role-tip-doc-link">
                <i class="fas fa-external-link-alt"></i> More info: RightKnightToFight's Guide
              </a>
            </div>
          </div>
        </div>
        {{/if}}
      </div>
    </div>
    <button type="button" data-action="autofill" class="dhac-btn-autofill" title="Auto-fill stats from SRD benchmarks">
      <i class="fas fa-magic"></i> Auto-fill
    </button>
  </div>

  {{!-- ==================== MAIN CONTENT ==================== --}}
  <div class="dhac-main">

    {{!-- Left Column: Stats --}}
    <div class="dhac-column dhac-col-stats">
      <h3 class="dhac-section-title"><i class="fas fa-shield-alt"></i> Combat Stats</h3>

      <div class="dhac-stat-row">
        <div class="dhac-stat">
          <label>Difficulty {{#if benchmarkStr}}<span class="dhac-range">({{benchmarkStr.difficulty}})</span>{{/if}}</label>
          <input type="number" name="difficulty" value="{{difficulty}}" />
        </div>
        {{#if isMinionRole}}
        <div class="dhac-stat">
          <label>Minion Passive {{#if minionDiceRangeStr}}<span class="dhac-range">({{minionDiceRangeStr}})</span>{{/if}}</label>
          <input type="number" name="minionPassiveValue" value="{{minionPassiveValue}}" min="1" />
          <input type="hidden" name="hp" value="1" />
        </div>
        {{else}}
        <div class="dhac-stat">
          <label>HP {{#if benchmarkStr}}<span class="dhac-range">({{benchmarkStr.hp}})</span>{{/if}}</label>
          <input type="number" name="hp" value="{{hp}}" />
        </div>
        {{/if}}
        <div class="dhac-stat">
          <label>Stress {{#if benchmarkStr}}<span class="dhac-range">({{benchmarkStr.stress}})</span>{{/if}}</label>
          <input type="number" name="stress" value="{{stress}}" />
        </div>
      </div>

      <div class="dhac-stat-row">
        {{#if isMinionRole}}
        <input type="hidden" name="majorThreshold" value="0" />
        <input type="hidden" name="severeThreshold" value="0" />
        <div class="dhac-stat">
          <label>ATK {{#if benchmarkStr}}<span class="dhac-range">({{benchmarkStr.atk}})</span>{{/if}}</label>
          <input type="number" name="atk" value="{{atk}}" />
        </div>
        <div class="dhac-stat">
          <label>Group Atk {{#if minionDiceRangeStr}}<span class="dhac-range">({{minionDiceRangeStr}})</span>{{/if}}</label>
          <input type="number" name="groupAttackDamage" value="{{groupAttackDamage}}" min="0" />
        </div>
        <input type="hidden" name="groupAttackType" value="{{groupAttackType}}" />
        {{else}}
        <div class="dhac-stat">
          <label>Major {{#if benchmarkStr}}<span class="dhac-range">({{benchmarkStr.major}})</span>{{/if}}</label>
          <input type="number" name="majorThreshold" value="{{majorThreshold}}" />
        </div>
        <div class="dhac-stat">
          <label>Severe {{#if benchmarkStr}}<span class="dhac-range">({{benchmarkStr.severe}})</span>{{/if}}</label>
          <input type="number" name="severeThreshold" value="{{severeThreshold}}" />
        </div>
        <div class="dhac-stat">
          <label>ATK {{#if benchmarkStr}}<span class="dhac-range">({{benchmarkStr.atk}})</span>{{/if}}</label>
          <input type="number" name="atk" value="{{atk}}" />
        </div>
        {{/if}}
      </div>

      <h3 class="dhac-section-title"><i class="fas fa-crosshairs"></i> Attack {{#if benchmarkStr}}<span class="dhac-range">({{benchmarkStr.dice}})</span>{{/if}}</h3>
      <div class="dhac-field-row">
        <div class="dhac-actor-image-controls">
          <button type="button" class="dhac-actor-image-btn" data-action="pickAttackImage" title="Choose standard attack image">
            <img src="{{weaponImg}}" alt="" class="dhac-actor-image" />
          </button>
          <button type="button" class="dhac-feature-image-reset-btn" data-action="resetAttackImage" title="Reset attack image">
            <i class="fas fa-rotate-left"></i>
          </button>
          <input type="hidden" name="weaponImg" value="{{weaponImg}}" />
        </div>
        <div class="dhac-field" style="flex:2">
          <label>Weapon Name</label>
          <input type="text" name="weaponName" value="{{weaponName}}" placeholder="e.g. Claws" />
        </div>
        <div class="dhac-field" style="flex:1">
          <label>Range</label>
          <select name="weaponRange">
            {{#each ranges}}
            <option value="{{@key}}" {{#if (eq @key ../weaponRange)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>
        </div>
      </div>

      <div class="dhac-field-row">
        {{#if isMinionRole}}
        <div class="dhac-field">
          <label>Flat Damage</label>
          <input type="number" name="weaponDamageFlat" value="{{weaponDamageFlat}}" min="0" />
        </div>
        {{else}}
        <div class="dhac-field">
          <label>Count</label>
          <input type="number" name="weaponDamageCount" value="{{weaponDamageCount}}" min="1" />
        </div>
        <div class="dhac-field">
          <label>Dice</label>
          <select name="weaponDamageDice">
            <option value="d4" {{#if (eq weaponDamageDice "d4")}}selected{{/if}}>d4</option>
            <option value="d6" {{#if (eq weaponDamageDice "d6")}}selected{{/if}}>d6</option>
            <option value="d8" {{#if (eq weaponDamageDice "d8")}}selected{{/if}}>d8</option>
            <option value="d10" {{#if (eq weaponDamageDice "d10")}}selected{{/if}}>d10</option>
            <option value="d12" {{#if (eq weaponDamageDice "d12")}}selected{{/if}}>d12</option>
            <option value="d20" {{#if (eq weaponDamageDice "d20")}}selected{{/if}}>d20</option>
          </select>
        </div>
        <div class="dhac-field">
          <label>Bonus</label>
          <input type="number" name="weaponDamageBonus" value="{{weaponDamageBonus}}" />
        </div>
        {{/if}}
        <div class="dhac-field">
          <label>Type</label>
          <select name="weaponDamageType">
            <option value="physical" {{#if (eq weaponDamageType "physical")}}selected{{/if}}>Physical</option>
            <option value="magical" {{#if (eq weaponDamageType "magical")}}selected{{/if}}>Magical</option>
          </select>
        </div>
      </div>

      <h3 class="dhac-section-title"><i class="fas fa-book"></i> Details</h3>
      <div class="dhac-field">
        <label>Description</label>
        <textarea name="description" rows="4" placeholder="Appearance and demeanor...">{{description}}</textarea>
      </div>
      <div class="dhac-field">
        <label>Motives & Tactics</label>
        <textarea name="motives" rows="3" placeholder="e.g. Devour, terrify, protect territory">{{motives}}</textarea>
      </div>
      <div class="dhac-experiences-header">
        <label>Experience {{#if expRange}}<span class="dhac-range">({{expRange}})</span>{{/if}}</label>
        <button type="button" data-action="addExperience" class="dhac-btn-add-inline"><i class="fas fa-plus"></i> Add</button>
      </div>
      <div class="dhac-experiences-list">
        {{#each experiences}}
        <div class="dhac-field-row dhac-experience-row">
          <div class="dhac-field" style="flex:2">
            <input type="text" name="experience.{{@index}}.name" value="{{this.name}}" placeholder="e.g. Stealth" />
          </div>
          <div class="dhac-field" style="flex:1">
            <input type="number" name="experience.{{@index}}.bonus" value="{{this.bonus}}" />
          </div>
          <button type="button" data-action="removeExperience" data-experience-id="{{this.id}}" class="dhac-btn-remove" title="Remove experience"><i class="fas fa-trash"></i></button>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- Right Column: Features --}}
    <div class="dhac-column dhac-col-features">
      <input type="hidden" name="rightTab" value="{{#if isEffectsTab}}effects{{else}}features{{/if}}" />
      <div class="dhac-features-header">
        <div class="dhac-right-tabs">
          <button type="button" data-action="switchRightTab" data-tab="features" class="dhac-right-tab {{#if isFeaturesTab}}is-active{{/if}}">
            <i class="fas fa-star"></i> Features ({{features.length}})
          </button>
          <button type="button" data-action="switchRightTab" data-tab="effects" class="dhac-right-tab {{#if isEffectsTab}}is-active{{/if}}">
            <i class="fas fa-bolt"></i> Effects
          </button>
        </div>
        {{#if isFeaturesTab}}
        <button type="button" data-action="addFeature" class="dhac-btn-add"><i class="fas fa-plus"></i> Add</button>
        {{/if}}
      </div>

      {{#if isFeaturesTab}}
      <div class="dhac-features-scroll">
        {{#if isMinionRole}}
        <div class="dhac-feature-card dhac-feature-pinned">
          <div class="dhac-feature-top">
            <button type="button" class="dhac-feature-image-btn" data-action="pickPinnedFeatureImage" data-pinned-key="minionPassive" title="Choose feature image">
              <img src="{{minionPassiveImg}}" alt="" class="dhac-feature-image" />
            </button>
            <button type="button" class="dhac-feature-image-reset-btn" data-action="resetPinnedFeatureImage" data-pinned-key="minionPassive" title="Reset feature image">
              <i class="fas fa-undo"></i>
            </button>
          </div>
          <div class="dhac-pinned-feature-header">
            <span class="dhac-feature-pinned-type">Passive</span>
            {{#if minionDiceRangeStr}}<span class="dhac-range">({{minionDiceRangeStr}})</span>{{/if}}
            <span class="dhac-pinned-lock" title="Auto-generated for minion role"><i class="fas fa-lock"></i></span>
          </div>
          <div class="dhac-feature-pinned-name">Minion<span class="dhac-pinned-x">({{minionPassiveValue}})</span></div>
          <div class="dhac-feature-pinned-desc">This adversary is defeated when they take any damage. For every <strong class="dhac-pinned-passive-mid">{{minionPassiveValue}}</strong> damage a PC deals to this adversary, defeat an additional Minion within range the attack would succeed against.</div>
        </div>
        <div class="dhac-feature-card dhac-feature-pinned">
          <div class="dhac-feature-top">
            <button type="button" class="dhac-feature-image-btn" data-action="pickPinnedFeatureImage" data-pinned-key="minionGroupAttack" title="Choose feature image">
              <img src="{{minionGroupAttackImg}}" alt="" class="dhac-feature-image" />
            </button>
            <button type="button" class="dhac-feature-image-reset-btn" data-action="resetPinnedFeatureImage" data-pinned-key="minionGroupAttack" title="Reset feature image">
              <i class="fas fa-undo"></i>
            </button>
          </div>
          <div class="dhac-pinned-feature-header">
            <span class="dhac-feature-pinned-type">Action</span>
            {{#if minionDiceRangeStr}}<span class="dhac-range">({{minionDiceRangeStr}})</span>{{/if}}
            <span class="dhac-pinned-lock" title="Auto-generated for minion role"><i class="fas fa-lock"></i></span>
          </div>
          <div class="dhac-feature-pinned-name">Group Attack</div>
          <div class="dhac-feature-pinned-desc">Spend a Fear to choose a target and spotlight all adversaries within Close range of them. Those Minions move into Melee range of the target and make one shared attack roll. On a success, they deal <strong><span class="dhac-pinned-group-dmg">{{groupAttackDamage}}</span></strong> <span class="dhac-pinned-group-type">{{groupAttackType}}</span> damage each. Combine this damage.</div>
          <div class="dhac-group-attack-type-row">
            <button type="button" class="dhac-type-toggle {{#if (eq groupAttackType 'physical')}}is-on{{/if}}" data-action="toggleGroupAttackType" data-type="physical">Physical</button>
            <button type="button" class="dhac-type-toggle {{#if (eq groupAttackType 'magical')}}is-on{{/if}}" data-action="toggleGroupAttackType" data-type="magical">Magical</button>
          </div>
        </div>
        {{/if}}
        {{#if isHordeRole}}
        <div class="dhac-feature-card dhac-feature-pinned">
          <div class="dhac-feature-top">
            <button type="button" class="dhac-feature-image-btn" data-action="pickPinnedFeatureImage" data-pinned-key="horde" title="Choose feature image">
              <img src="{{hordeFeatureImg}}" alt="" class="dhac-feature-image" />
            </button>
            <button type="button" class="dhac-feature-image-reset-btn" data-action="resetPinnedFeatureImage" data-pinned-key="horde" title="Reset feature image">
              <i class="fas fa-undo"></i>
            </button>
          </div>
          <div class="dhac-pinned-feature-header">
            <span class="dhac-feature-pinned-type">Passive</span>
            <span class="dhac-pinned-lock" title="Auto-generated for horde role"><i class="fas fa-lock"></i></span>
          </div>
          <div class="dhac-feature-pinned-name">Horde</div>
          <div class="dhac-horde-suggestion">
            <i class="fas fa-dice"></i> Halved dice: <strong class="dhac-horde-avg">{{hordeHalvedAvg}}</strong> <span class="dhac-horde-type">{{hordeWeaponDamageType}}</span>
          </div>
          <div class="dhac-feature-pinned-desc">When the &lt;name&gt; have marked half or more of their HP, their standard attack deals <strong><span class="dhac-horde-dmg">{{hordeCurrentDamage}}</span></strong> <span class="dhac-horde-type">{{hordeWeaponDamageType}}</span> damage instead.</div>
          <div class="dhac-horde-footer">
            {{#unless hordeAutoHalve}}
            <input
              type="text"
              name="hordeDamage"
              value="{{hordeCurrentDamage}}"
              class="dhac-horde-custom-input"
              placeholder="e.g. 2d6+3"
            />
            {{/unless}}
            <button
              type="button"
              data-action="toggleHordeAutoHalve"
              class="dhac-horde-auto-btn{{#if hordeAutoHalve}} is-on{{/if}}"
              title="{{#if hordeAutoHalve}}Auto-halve is ON — click to set custom damage{{else}}Auto-halve is OFF — click to use suggested damage{{/if}}"
            >
              <i class="fas fa-scissors"></i> Auto-Halve: {{#if hordeAutoHalve}}On{{else}}Off{{/if}}
            </button>
          </div>
        </div>
        {{/if}}
        {{#each features}}
        <div class="dhac-feature-card">
          <div class="dhac-feature-top">
            <button
              type="button"
              class="dhac-feature-image-btn"
              data-action="pickFeatureImage"
              data-feature-index="{{@index}}"
              title="Choose feature image"
            >
              <img src="{{this.img}}" alt="" class="dhac-feature-image" />
            </button>
            <button
              type="button"
              class="dhac-feature-image-reset-btn"
              data-action="resetFeatureImage"
              data-feature-index="{{@index}}"
              title="Reset feature image"
            >
              <i class="fas fa-rotate-left"></i>
            </button>
            <input type="hidden" name="feature.{{@index}}.img" value="{{this.img}}" />
            <input type="text" name="feature.{{@index}}.name" value="{{this.name}}" placeholder="Feature Name (auto-fills if blank)" class="dhac-feature-name-input" />
            <select name="feature.{{@index}}.formType" class="dhac-feature-type-select">
              <option value="passive" {{#if (eq this.formType "passive")}}selected{{/if}}>Passive</option>
              <option value="action" {{#if (eq this.formType "action")}}selected{{/if}}>Action</option>
              <option value="reaction" {{#if (eq this.formType "reaction")}}selected{{/if}}>Reaction</option>
            </select>
            <button type="button" data-action="removeFeature" data-feature-id="{{this.id}}" class="dhac-btn-remove" title="Remove"><i class="fas fa-trash"></i></button>
          </div>
          <textarea name="feature.{{@index}}.description" data-desc-index="{{@index}}" rows="1" placeholder="Write naturally — buttons auto-detect from your text. Example: Mark a Stress to make an attack against all targets within Close range dealing 2d8+4 physical damage. Each target must make an Agility Reaction Roll.">{{this.description}}</textarea>
          <div class="dhac-toggles-row" data-toggles-index="{{@index}}">
            {{!-- Toggles rendered by JS _onRender --}}
          </div>
        </div>
        {{/each}}
      </div>

      <div class="dhac-btn-row-bottom">
        <button type="button" data-action="addFeature" class="dhac-btn-add-bottom"><i class="fas fa-plus"></i> Add Feature</button>
        <button type="button" data-action="addCommonFeatures" class="dhac-btn-common-features" title="Add common features for the selected role"><i class="fas fa-book-open"></i> Add Common Features</button>
      </div>
      {{/if}}

      {{#if isEffectsTab}}
      <div class="dhac-features-scroll">
        <div class="dhac-feature-card">
          <div class="dhac-effects-panel">
            <p class="dhac-effects-help">
              These toggles create actor effects and set the corresponding values to 1 (Override).
            </p>

            <div class="dhac-effects-group">
              <div class="dhac-effects-group-title">Severity Reduction (reduce severity by 1 to 3)</div>
              <div class="dhac-effect-row">
                <button
                  type="button"
                  data-action="toggleEffectFlag"
                  data-effect-key="physicalSeverityReductionEnabled"
                  class="dhac-effect-toggle {{#if effects.physicalSeverityReductionEnabled}}is-on{{/if}}"
                >
                  <span class="dhac-effect-toggle-label">Physical Severity Reduction</span>
                  <span class="dhac-effect-toggle-state">{{#if effects.physicalSeverityReductionEnabled}}On{{else}}Off{{/if}}</span>
                </button>
                <select
                  class="dhac-effect-value-input"
                  name="effect.physicalSeverityReduction"
                  title="1-3 = reduce severity by that amount"
                >
                  <option value="1" {{#if (eq effects.physicalSeverityReduction 1)}}selected{{/if}}>1</option>
                  <option value="2" {{#if (eq effects.physicalSeverityReduction 2)}}selected{{/if}}>2</option>
                  <option value="3" {{#if (eq effects.physicalSeverityReduction 3)}}selected{{/if}}>3</option>
                </select>
              </div>

              <div class="dhac-effect-row">
                <button
                  type="button"
                  data-action="toggleEffectFlag"
                  data-effect-key="magicSeverityReductionEnabled"
                  class="dhac-effect-toggle {{#if effects.magicSeverityReductionEnabled}}is-on{{/if}}"
                >
                  <span class="dhac-effect-toggle-label">Magic Severity Reduction</span>
                  <span class="dhac-effect-toggle-state">{{#if effects.magicSeverityReductionEnabled}}On{{else}}Off{{/if}}</span>
                </button>
                <select
                  class="dhac-effect-value-input"
                  name="effect.magicSeverityReduction"
                  title="1-3 = reduce severity by that amount"
                >
                  <option value="1" {{#if (eq effects.magicSeverityReduction 1)}}selected{{/if}}>1</option>
                  <option value="2" {{#if (eq effects.magicSeverityReduction 2)}}selected{{/if}}>2</option>
                  <option value="3" {{#if (eq effects.magicSeverityReduction 3)}}selected{{/if}}>3</option>
                </select>
              </div>
            </div>

            <div class="dhac-effects-group">
              <div class="dhac-effects-group-title">Resistance (half damage)</div>
              <button
                type="button"
                data-action="toggleEffectFlag"
                data-effect-key="physicalResistance"
                class="dhac-effect-toggle {{#if effects.physicalResistance}}is-on{{/if}}"
              >
                <span class="dhac-effect-toggle-label">Physical Resistance</span>
                <span class="dhac-effect-toggle-state">{{#if effects.physicalResistance}}On{{else}}Off{{/if}}</span>
              </button>

              <button
                type="button"
                data-action="toggleEffectFlag"
                data-effect-key="magicResistance"
                class="dhac-effect-toggle {{#if effects.magicResistance}}is-on{{/if}}"
              >
                <span class="dhac-effect-toggle-label">Magic Resistance</span>
                <span class="dhac-effect-toggle-state">{{#if effects.magicResistance}}On{{else}}Off{{/if}}</span>
              </button>
            </div>

            <div class="dhac-effects-group">
              <div class="dhac-effects-group-title">Immunity</div>
              <button
                type="button"
                data-action="toggleEffectFlag"
                data-effect-key="physicalImmunity"
                class="dhac-effect-toggle {{#if effects.physicalImmunity}}is-on{{/if}}"
              >
                <span class="dhac-effect-toggle-label">Physical Immunity</span>
                <span class="dhac-effect-toggle-state">{{#if effects.physicalImmunity}}On{{else}}Off{{/if}}</span>
              </button>

              <button
                type="button"
                data-action="toggleEffectFlag"
                data-effect-key="magicImmunity"
                class="dhac-effect-toggle {{#if effects.magicImmunity}}is-on{{/if}}"
              >
                <span class="dhac-effect-toggle-label">Magic Immunity</span>
                <span class="dhac-effect-toggle-state">{{#if effects.magicImmunity}}On{{else}}Off{{/if}}</span>
              </button>
            </div>

          </div>
        </div>
      </div>
      {{/if}}
    </div>
  </div>

  {{!-- ==================== FOOTER ==================== --}}
  <div class="dhac-footer">
    <button type="button" data-action="resetForm" class="dhac-btn-reset"><i class="fas fa-undo"></i> Reset</button>
